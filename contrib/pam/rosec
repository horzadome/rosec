# /etc/pam.d/rosec — PAM config snippet for rosec auto-unlock.
#
# Include this from your LOCAL login PAM config (not system-login,
# which is also used by SSH and other remote services where there
# is no D-Bus session bus):
#
#   # /etc/pam.d/system-local-login (after the existing includes):
#   auth     include  rosec
#   session  include  rosec
#
# Screen lockers (hyprlock, swaylock, etc.) that include 'login'
# will pick this up automatically via the include chain:
#   login -> system-local-login -> rosec
#
# Both lines are marked `optional` — pam_rosec.so CANNOT block login
# or account lockout under any circumstances.

auth     optional  pam_rosec.so
session  optional  pam_rosec.so
